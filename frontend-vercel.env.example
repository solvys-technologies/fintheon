# ============================================
# Fintheon Frontend - Vercel Environment Variables
# ============================================
# Add these in Vercel Dashboard > Settings > Environment Variables
# Apply to: Production, Preview, Development
#
# Or use Vercel CLI:
# vercel env add VITE_SUPABASE_URL production
# vercel env add VITE_API_URL production
#
# IMPORTANT: Replace ALL placeholders with your actual values

# Supabase Authentication (Required)
# Get from: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Backend API URL (Required)
# Production: https://fintheon.fly.dev
# Local development: http://localhost:8080
VITE_API_URL=https://fintheon.fly.dev

# Sentry Monitoring (Recommended)
# Frontend DSN from Sentry project settings
VITE_SENTRY_DSN=https://public-key.ingest.us.sentry.io/project-id
# Tune sampling in code-friendly strings
VITE_SENTRY_TRACES_SAMPLE_RATE=0.15
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.05
VITE_SENTRY_REPLAYS_ERROR_SAMPLE_RATE=1.0
# Optional: propagate release identifiers
VITE_SENTRY_RELEASE=$VERCEL_GIT_COMMIT_SHA

# Build-time Sentry configuration (required if uploading sourcemaps)
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=vercel-managed-token
SENTRY_RELEASE=$VERCEL_GIT_COMMIT_SHA
