#!/bin/bash
# ============================================================================
# Fintheon CLI — repo-level entry point
# ============================================================================
# First time:   ./fintheon install
# After that:   fintheon start | stop | update | logs
# ============================================================================

# Resolve through symlinks so `fintheon` works from /usr/local/bin
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
FINTHEON_ROOT="$(cd "$(dirname "$SOURCE")" && pwd)"

# ── Solvys Gold ANSI palette ──────────────────────────────────────────────────
_R='\033[0m'
_GOLD='\033[38;2;199;159;74m'
_CREAM='\033[38;2;240;234;214m'
_DIM='\033[38;2;100;85;50m'
_FIRE1='\033[38;2;255;100;20m'
_FIRE2='\033[38;2;255;160;40m'
_FIRE3='\033[38;2;255;210;80m'
_EMBER='\033[38;2;180;60;20m'
_GREEN='\033[38;2;120;200;120m'
_RED='\033[38;2;220;60;60m'
_YELLOW='\033[38;2;220;190;80m'
_BOLD='\033[1m'

ok()   { echo -e "  ${_GREEN}✓${_R} ${_CREAM}$1${_R}"; }
warn() { echo -e "  ${_YELLOW}⚠${_R} ${_CREAM}$1${_R}"; }
fail() { echo -e "  ${_RED}✗${_R} ${_CREAM}$1${_R}"; exit 1; }
info() { echo -e "  ${_DIM}·${_R} ${_CREAM}$1${_R}"; }

torch_banner() {
  local title="$1"
  local subtitle="${2:-}"
  echo ""
  echo -e "      ${_FIRE3}  )  ${_R}                                    ${_FIRE3}  (  ${_R}"
  echo -e "      ${_FIRE2} ( \\ ${_R}                                    ${_FIRE2} / ) ${_R}"
  echo -e "      ${_FIRE1}  )( ${_R}                                    ${_FIRE1}  )( ${_R}"
  echo -e "      ${_EMBER} /|\\${_R}                                     ${_EMBER} /|\\${_R}"
  echo -e "      ${_GOLD}]|||[${_R}  ${_GOLD}╔══════════════════════════════╗${_R}  ${_GOLD}]|||[${_R}"
  printf -v _t "%-30s" "$title"
  echo -e "      ${_GOLD}]|||[${_R}  ${_GOLD}║${_R} ${_BOLD}${_GOLD}${_t}${_R}${_GOLD}║${_R}  ${_GOLD}]|||[${_R}"
  if [[ -n "$subtitle" ]]; then
    printf -v _s "%-30s" "$subtitle"
    echo -e "      ${_GOLD}]|||[${_R}  ${_GOLD}║${_R} ${_DIM}${_s}${_R}${_GOLD}║${_R}  ${_GOLD}]|||[${_R}"
  fi
  echo -e "      ${_GOLD}]|||[${_R}  ${_GOLD}╚══════════════════════════════╝${_R}  ${_GOLD}]|||[${_R}"
  echo -e "      ${_DIM} ╨╨╨ ${_R}                                    ${_DIM} ╨╨╨ ${_R}"
  echo ""
}

torch_status() {
  local line1="$1" line2="${2:-}" line3="${3:-}" line4="${4:-}"
  echo ""
  echo -e "      ${_FIRE3}  )  ${_R}                                    ${_FIRE3}  (  ${_R}"
  echo -e "      ${_FIRE2} ( \\ ${_R}                                    ${_FIRE2} / ) ${_R}"
  echo -e "      ${_FIRE1}  )( ${_R}                                    ${_FIRE1}  )( ${_R}"
  echo -e "      ${_EMBER} /|\\${_R}                                     ${_EMBER} /|\\${_R}"
  echo -e "      ${_GOLD}]|||[${_R}  ${_GOLD}╔══════════════════════════════╗${_R}  ${_GOLD}]|||[${_R}"
  printf -v _p1 "%-30s" "$line1"
  echo -e "      ${_GOLD}]|||[${_R}  ${_GOLD}║${_R} ${_BOLD}${_GOLD}${_p1}${_R}${_GOLD}║${_R}  ${_GOLD}]|||[${_R}"
  echo -e "      ${_GOLD}]|||[${_R}  ${_GOLD}║${_R}                                ${_GOLD}║${_R}  ${_GOLD}]|||[${_R}"
  for line in "$line2" "$line3" "$line4"; do
    if [[ -n "$line" ]]; then
      printf -v _px "%-30s" "$line"
      echo -e "      ${_GOLD}]|||[${_R}  ${_GOLD}║${_R} ${_CREAM}${_px}${_R}${_GOLD}║${_R}  ${_GOLD}]|||[${_R}"
    fi
  done
  echo -e "      ${_GOLD}]|||[${_R}  ${_GOLD}╚══════════════════════════════╝${_R}  ${_GOLD}]|||[${_R}"
  echo -e "      ${_DIM} ╨╨╨ ${_R}                                    ${_DIM} ╨╨╨ ${_R}"
  echo ""
}

section() {
  echo ""
  echo -e "  ${_GOLD}── $1 ${_DIM}─────────────────────────────────────${_R}"
}

# Optional public bootstrap values. Infisical is canonical; repo installers do
# not embed live project keys.
_SUPABASE_URL="${FINTHEON_SETUP_SUPABASE_URL:-${SUPABASE_URL:-}}"
_SUPABASE_ANON_KEY="${FINTHEON_SETUP_SUPABASE_ANON_KEY:-${SUPABASE_ANON_KEY:-}}"
_DATABASE_URL="${FINTHEON_SETUP_DATABASE_URL:-${DATABASE_URL:-}}"

do_install() {
  torch_banner "FINTHEON INSTALL" "No API keys needed. Sign in."

  local SHELL_PROFILE="$HOME/.zprofile"

  # ── 1. Core runtimes (Homebrew, Node, Bun, Python, uv) ────────────

  section "Core Runtimes"

  # Homebrew
  if ! command -v brew &>/dev/null; then
    info "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    if [[ -f /opt/homebrew/bin/brew ]]; then
      eval "$(/opt/homebrew/bin/brew shellenv)"
      grep -q 'brew shellenv' "$SHELL_PROFILE" 2>/dev/null || \
        echo 'eval "$(/opt/homebrew/bin/brew shellenv)"' >> "$SHELL_PROFILE"
    fi
  fi
  ok "Homebrew"

  # Node.js
  if command -v node &>/dev/null; then
    NODE_MAJOR=$(node --version | sed 's/v//' | cut -d. -f1)
    [[ "$NODE_MAJOR" -lt 20 ]] && { brew install node@22 && brew link --overwrite node@22 2>/dev/null || true; }
  else
    brew install node@22 && brew link --overwrite node@22 2>/dev/null || true
  fi
  ok "Node.js $(node --version)"

  # Bun
  if ! command -v bun &>/dev/null; then
    curl -fsSL https://bun.sh/install | bash
    export BUN_INSTALL="$HOME/.bun"
    export PATH="$BUN_INSTALL/bin:$PATH"
    grep -q '.bun/bin' "$SHELL_PROFILE" 2>/dev/null || {
      echo 'export BUN_INSTALL="$HOME/.bun"' >> "$SHELL_PROFILE"
      echo 'export PATH="$BUN_INSTALL/bin:$PATH"' >> "$SHELL_PROFILE"
    }
  fi
  ok "Bun $(bun --version)"

  # Python 3 (for Hermes agent + Twitter CLI)
  if ! command -v python3 &>/dev/null; then
    brew install python@3.11 2>/dev/null || true
  fi
  ok "Python $(python3 --version 2>/dev/null | cut -d' ' -f2 || echo 'via Xcode')"

  # uv (fast Python package manager — installs Twitter CLI)
  if ! command -v uv &>/dev/null; then
    info "Installing uv..."
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="$HOME/.local/bin:$PATH"
    grep -q '.local/bin' "$SHELL_PROFILE" 2>/dev/null || \
      echo 'export PATH="$HOME/.local/bin:$PATH"' >> "$SHELL_PROFILE"
  fi
  ok "uv $(uv --version 2>/dev/null | head -1)"

  # ── 2. Platform tools (Hermes, Twitter CLI) ───────────────────────

  section "Platform Tools"

  # Hermes Agent — multi-agent orchestration (Nous Research)
  if ! command -v hermes &>/dev/null; then
    info "Installing Hermes agent..."
    pip3 install hermes-agent 2>/dev/null || python3 -m pip install hermes-agent 2>/dev/null || true
  fi
  if command -v hermes &>/dev/null; then
    ok "Hermes $(hermes --version 2>/dev/null | head -1)"
  else
    warn "Hermes install failed — install manually: pip3 install hermes-agent"
  fi

  # Initialize Hermes config if missing
  if [[ ! -d "$HOME/.hermes" ]]; then
    mkdir -p "$HOME/.hermes/agents/main/sessions" "$HOME/.hermes/config"
    cat > "$HOME/.hermes/config/default.json" << HERMESEOF
{
  "provider": "deepseek",
  "base_url": "https://api.deepseek.com/v1",
  "model": "deepseek-reasoner",
  "app_name": "Fintheon-PIC-Hermes",
  "fintheon_root": "$FINTHEON_ROOT",
  "backend_url": "http://localhost:8080",
  "agents": {
    "harper": { "role": "CAO", "model": "deepseek-reasoner" },
    "oracle": { "role": "All-Seer", "model": "deepseek-reasoner" },
    "feucht": { "role": "Futures & Risk", "model": "deepseek-reasoner" },
    "consul": { "role": "Fundamentals", "model": "deepseek-reasoner" },
    "herald": { "role": "News", "model": "deepseek-reasoner" }
  }
}
HERMESEOF
    ok "Hermes config initialized at ~/.hermes"
  fi

  # Twitter CLI — X feed polling for RiskFlow
  if ! command -v twitter &>/dev/null && [[ ! -x "$HOME/.local/bin/twitter" ]]; then
    info "Installing Twitter CLI..."
    uv tool install twitter-cli 2>/dev/null || true
    export PATH="$HOME/.local/bin:$PATH"
  fi
  TWITTER_BIN="$(command -v twitter 2>/dev/null || echo "$HOME/.local/bin/twitter")"
  if [[ -x "$TWITTER_BIN" ]]; then
    ok "Twitter CLI ($TWITTER_BIN)"
  else
    warn "Twitter CLI install failed — install manually: uv tool install twitter-cli"
  fi

  # ── 4. JS dependencies ────────────────────────────────────────────

  section "Dependencies"
  cd "$FINTHEON_ROOT"
  bun install 2>/dev/null || bun install
  ok "Root deps"

  cd "$FINTHEON_ROOT/backend-hono" && (bun install --omit=peer 2>/dev/null || bun install --omit=peer)
  cd "$FINTHEON_ROOT"
  ok "Backend deps"

  if [[ -d frontend && -f frontend/package.json ]]; then
    cd "$FINTHEON_ROOT/frontend" && (bun install 2>/dev/null || bun install)
    cd "$FINTHEON_ROOT"
    ok "Frontend deps"
  fi

  # ── Bootstrap .env ─────────────────────────────────────────────────

  BACKEND_ENV="$FINTHEON_ROOT/backend-hono/.env"
  if [[ -f "$BACKEND_ENV" ]]; then
    [[ -z "$_DATABASE_URL" ]] || grep -q "^DATABASE_URL=" "$BACKEND_ENV" || echo "DATABASE_URL=$_DATABASE_URL" >> "$BACKEND_ENV"
    [[ -z "$_SUPABASE_URL" ]] || grep -q "^SUPABASE_URL=" "$BACKEND_ENV" || echo "SUPABASE_URL=$_SUPABASE_URL" >> "$BACKEND_ENV"
    [[ -z "$_SUPABASE_ANON_KEY" ]] || grep -q "^SUPABASE_ANON_KEY=" "$BACKEND_ENV" || echo "SUPABASE_ANON_KEY=$_SUPABASE_ANON_KEY" >> "$BACKEND_ENV"
    grep -q "^PORT=" "$BACKEND_ENV" || echo "PORT=8080" >> "$BACKEND_ENV"
    grep -q "^ENABLE_CENTRAL_SCORING=" "$BACKEND_ENV" || echo "ENABLE_CENTRAL_SCORING=true" >> "$BACKEND_ENV"
    grep -q "^AI_PRIMARY_PROVIDER=" "$BACKEND_ENV" || echo "AI_PRIMARY_PROVIDER=deepseek-direct" >> "$BACKEND_ENV"
    grep -q "^DISPATCH_SCHEDULER_ENABLED=" "$BACKEND_ENV" || echo "DISPATCH_SCHEDULER_ENABLED=true" >> "$BACKEND_ENV"
    grep -q "^HERMES_BOARDROOM_CRON=" "$BACKEND_ENV" || echo "HERMES_BOARDROOM_CRON=0,30 7-9 * * 1-5" >> "$BACKEND_ENV"
    grep -q "^HERMES_BOARDROOM_TZ=" "$BACKEND_ENV" || echo "HERMES_BOARDROOM_TZ=America/New_York" >> "$BACKEND_ENV"
    ok "Existing .env updated"
  else
    cat > "$BACKEND_ENV" << ENVEOF
# Fintheon Backend — Bootstrap Environment
# Secrets are loaded from the cloud vault on boot. No API keys needed here.
PORT=8080
SUPABASE_URL=${_SUPABASE_URL}
SUPABASE_ANON_KEY=${_SUPABASE_ANON_KEY}
ENABLE_CENTRAL_SCORING=true
DISPATCH_SCHEDULER_ENABLED=true

AI_PRIMARY_PROVIDER=deepseek-direct

# Scheduling (ET)
HERMES_BOARDROOM_CRON=0,30 7-9 * * 1-5
HERMES_BOARDROOM_TZ=America/New_York
BOARDROOM_MEETING_WINDOW_MINUTES=90
BOARDROOM_MEETING_HOUR_LOCAL=10
HERMES_PREMARKET_CRON=0 8 * * 1-5
HERMES_POSTMARKET_CRON=30 16 * * 1-5
ENVEOF
    [[ -z "$_DATABASE_URL" ]] || echo "DATABASE_URL=$_DATABASE_URL" >> "$BACKEND_ENV"
    ok "Bootstrap .env created"
  fi

  FRONTEND_ENV="$FINTHEON_ROOT/frontend/.env.local"
  if [[ ! -f "$FRONTEND_ENV" ]]; then
    cat > "$FRONTEND_ENV" << FENVEOF
VITE_API_URL=http://localhost:8080
VITE_SUPABASE_URL=${_SUPABASE_URL}
VITE_SUPABASE_ANON_KEY=${_SUPABASE_ANON_KEY}
VITE_BYPASS_AUTH=false
FENVEOF
    ok "Frontend .env.local created"
  fi

  # ── Build ──────────────────────────────────────────────────────────

  info "Building..."
  cd "$FINTHEON_ROOT/backend-hono"
  bun run build 2>&1 | tail -1 && ok "Backend compiled" || warn "Backend build had issues"
  cd "$FINTHEON_ROOT"
  npx vite build 2>&1 | tail -1 && ok "Frontend built" || warn "Frontend build had issues"

  # ── Install CLI globally ───────────────────────────────────────────

  sudo mkdir -p /usr/local/bin 2>/dev/null || true
  sudo ln -sf "$FINTHEON_ROOT/fintheon" /usr/local/bin/fintheon
  sudo chmod +x /usr/local/bin/fintheon
  ok "'fintheon' command available globally"

  # ── Start ──────────────────────────────────────────────────────────

  do_start

  torch_status \
    "FINTHEON IS READY" \
    "Backend: http://localhost:8080" \
    "CLI: fintheon start|stop|update" \
    "Sign in with Google to begin."
  _close_terminal
}

do_start() {
  section "Starting Fintheon"
  cd "$FINTHEON_ROOT/backend-hono"
  lsof -ti:8080 | xargs kill -9 2>/dev/null || true
  sleep 1
  nohup bun run src/index.ts > /tmp/fintheon-backend.log 2>&1 &
  local pid=$!
  for i in {1..10}; do
    if curl -s localhost:8080/health > /dev/null 2>&1; then
      ok "Backend live (PID: $pid)"
      break
    fi
    sleep 2
    if [[ $i -eq 10 ]]; then
      warn "Backend slow — check: tail -f /tmp/fintheon-backend.log"
    fi
  done
  if [[ -d /Applications/Fintheon.app ]]; then
    open /Applications/Fintheon.app 2>/dev/null || true
  fi
}

_close_terminal() {
  # Give the user a moment to see the final banner, then close this terminal window
  sleep 2
  osascript -e 'tell application "Terminal" to close (every window whose name contains "fintheon")' 2>/dev/null || true
}

case "${1:-help}" in
  install|setup)
    do_install
    ;;
  update)
    bash "$FINTHEON_ROOT/scripts/fintheon-update.sh"
    ;;
  start)
    do_start
    ;;
  stop)
    info "Stopping Fintheon..."
    pkill -f "Fintheon" 2>/dev/null || true
    pkill -f "electron.*fintheon" 2>/dev/null || true
    lsof -ti:8080 | xargs kill -9 2>/dev/null || true
    ok "Stopped"
    ;;
  restart)
    "$0" stop
    sleep 1
    do_start
    ;;
  logs)
    tail -f /tmp/fintheon-backend.log
    ;;
  status)
    echo ""
    echo -e "  ${_GOLD}Fintheon Status${_R}"
    echo -e "  ${_DIM}────────────────────────────────${_R}"
    if lsof -i:8080 > /dev/null 2>&1; then
      ok "Backend running on :8080"
      curl -s localhost:8080/health | python3 -m json.tool 2>/dev/null || true
    else
      echo -e "  ${_RED}✗${_R} ${_CREAM}Backend not running${_R}"
    fi
    if pgrep -f "Fintheon" > /dev/null 2>&1; then
      ok "App running"
    else
      info "App not running"
    fi
    VERSION=$(cd "$FINTHEON_ROOT" && git describe --tags --always 2>/dev/null || echo "unknown")
    echo -e "  ${_DIM}·${_R} ${_CREAM}Version: ${_GOLD}$VERSION${_R}"
    echo ""
    ;;
  peers)
    if [[ -f "$FINTHEON_ROOT/scripts/peer-bootstrap.sh" ]]; then
      bash "$FINTHEON_ROOT/scripts/peer-bootstrap.sh"
    else
      echo "  peer-bootstrap.sh not found"
    fi
    ;;
  version)
    VERSION=$(cd "$FINTHEON_ROOT" && git describe --tags --always 2>/dev/null || echo "unknown")
    echo -e "  ${_GOLD}Fintheon ${_BOLD}$VERSION${_R}"
    ;;
  *)
    VERSION=$(cd "$FINTHEON_ROOT" && git describe --tags --always 2>/dev/null || echo "")
    echo ""
    echo -e "      ${_FIRE3}  )  ${_R}                              ${_FIRE3}  (  ${_R}"
    echo -e "      ${_FIRE2} ( \\ ${_R}  ${_BOLD}${_GOLD}FINTHEON${_R} ${_DIM}$VERSION${_R}      ${_FIRE2} / ) ${_R}"
    echo -e "      ${_FIRE1}  )( ${_R}  ${_DIM}Priced In Capital${_R}       ${_FIRE1}  )( ${_R}"
    echo -e "      ${_GOLD}]|||[${_R}                              ${_GOLD}]|||[${_R}"
    echo -e "      ${_DIM} ╨╨╨ ${_R}                              ${_DIM} ╨╨╨ ${_R}"
    echo ""
    echo -e "  ${_GOLD}Commands${_R}"
    echo -e "  ${_DIM}────────────────────────────────────────${_R}"
    echo -e "  ${_CREAM}fintheon ${_GOLD}install${_R}       ${_DIM}First-time setup${_R}"
    echo -e "  ${_CREAM}fintheon ${_GOLD}update${_R}        ${_DIM}Pull latest + rebuild${_R}"
    echo -e "  ${_CREAM}fintheon ${_GOLD}start${_R}         ${_DIM}Start backend + app${_R}"
    echo -e "  ${_CREAM}fintheon ${_GOLD}stop${_R}          ${_DIM}Stop everything${_R}"
    echo -e "  ${_CREAM}fintheon ${_GOLD}restart${_R}       ${_DIM}Stop + start${_R}"
    echo -e "  ${_CREAM}fintheon ${_GOLD}logs${_R}          ${_DIM}Tail backend logs${_R}"
    echo -e "  ${_CREAM}fintheon ${_GOLD}status${_R}        ${_DIM}Check if running${_R}"
    echo -e "  ${_CREAM}fintheon ${_GOLD}dispatchers${_R}   ${_DIM}Brief dispatch schedules${_R}"
    echo -e "  ${_CREAM}fintheon ${_GOLD}peers${_R}         ${_DIM}Twitter round-robin${_R}"
    echo -e "  ${_CREAM}fintheon ${_GOLD}version${_R}       ${_DIM}Show current version${_R}"
    echo ""
    ;;
esac
