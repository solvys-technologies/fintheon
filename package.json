{
  "name": "fintheon",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "bun",
  "dependencies": {
    "@ai-sdk/react": "^3.0.3",
    "@clerk/clerk-react": "^5.35.2",
    "@clerk/themes": "^2.2.26",
    "@sentry/react": "^10.32.1",
    "ai": "^6.0.3",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.484.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@tailwindcss/oxide": "^4.1.11",
    "@tailwindcss/vite": "^4.1.11",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8",
    "lightningcss": "^1.29.2",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5.8.3",
    "vite": "^6.2.5"
  },
  "optionalDependencies": {
    "rollup": "^4.44.1"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "frontend:install": "npm --prefix frontend install",
    "frontend:build": "npm --prefix frontend run build",
    "desktop:build": "npm run frontend:build && cd backend-hono && npm run build && cd .. && electron-builder --mac dmg",
    "release:mac": "npm run frontend:build && cd backend-hono && npm run build && cd .. && npx electron-builder --mac dmg",
    "release": "bash scripts/build-release.sh"
  },
  "build": {
    "appId": "io.solvys.fintheon",
    "productName": "Fintheon",
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "frontend/package.json"
    ],
    "extraResources": [
      {
        "from": "backend-hono/dist/",
        "to": "backend-hono/dist/"
      },
      {
        "from": "backend-hono/node_modules/",
        "to": "backend-hono/node_modules/"
      },
      {
        "from": "backend-hono/package.json",
        "to": "backend-hono/package.json"
      },
      {
        "from": "backend-hono/.env",
        "to": "backend-hono/.env"
      },
      {
        "from": "backend-hono/migrations/",
        "to": "backend-hono/migrations/"
      }
    ],
    "directories": {
      "output": "desktop-dist"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "electron/icons/icon.icns",
      "category": "public.app-category.finance"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "electron/icons/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "solvys-technologies",
      "repo": "pulse"
    }
  }
}
