{
  "name": "fintheon",
  "version": "5.22.9",
  "type": "module",
  "packageManager": "bun",
  "dependencies": {
    "@ai-sdk/react": "^3.0.3",
    "@assistant-ui/react": "^0.12.15",
    "@assistant-ui/react-ai-sdk": "^1.3.12",
    "@assistant-ui/react-markdown": "^0.12.5",
    "@livekit/components-react": "^2.9.20",
    "@livekit/components-styles": "^1.2.0",
    "@sentry/react": "^10.32.1",
    "@supabase/supabase-js": "^2.99.3",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.3",
    "clsx": "^2.1.1",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.35.2",
    "livekit-client": "^2.18.1",
    "lucide-react": "^0.484.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.11",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@clack/prompts": "^0.9.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/oxide": "^4.1.11",
    "@tailwindcss/vite": "^4.1.11",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8",
    "lightningcss": "^1.29.2",
    "playwright": "^1.58.2",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5.8.3",
    "vite": "^6.2.5"
  },
  "optionalDependencies": {
    "rollup": "^4.44.1"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "build": "npx vite build",
    "frontend:install": "cd frontend && bun install",
    "frontend:build": "cd frontend && bun run build",
    "desktop:build": "bun run frontend:build && electron-builder --mac dmg",
    "release:mac": "bun run frontend:build && cd backend-hono && bun run build && cd .. && bunx electron-builder --mac dmg",
    "release": "bash scripts/build-release.sh",
    "setup": "bun run scripts/setup.ts",
    "update": "bun run scripts/update.ts"
  },
  "build": {
    "appId": "io.solvys.fintheon",
    "productName": "Fintheon",
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "frontend/package.json"
    ],
    "directories": {
      "output": "desktop-dist"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "electron/icons/icon.icns",
      "category": "public.app-category.finance"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "electron/icons/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "solvys-technologies",
      "repo": "fintheon"
    }
  }
}
