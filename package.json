{
  "name": "fintheon",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "bun",
  "dependencies": {
    "@ai-sdk/react": "^3.0.3",
    "@sentry/react": "^10.32.1",
    "@supabase/supabase-js": "^2.99.3",
    "ai": "^6.0.3",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.484.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@clack/prompts": "^0.9.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/oxide": "^4.1.11",
    "@tailwindcss/vite": "^4.1.11",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8",
    "lightningcss": "^1.29.2",
    "playwright": "^1.58.2",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5.8.3",
    "vite": "^6.2.5"
  },
  "optionalDependencies": {
    "rollup": "^4.44.1"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "frontend:install": "cd frontend && bun install",
    "frontend:build": "cd frontend && bun run build",
    "desktop:build": "bun run frontend:build && electron-builder --mac dmg",
    "release:mac": "bun run frontend:build && cd backend-hono && bun run build && cd .. && bunx electron-builder --mac dmg",
    "release": "bash scripts/build-release.sh",
    "setup": "bun run scripts/setup.ts",
    "update": "bun run scripts/update.ts"
  },
  "build": {
    "appId": "io.solvys.fintheon",
    "productName": "Fintheon",
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "frontend/package.json"
    ],
    "directories": {
      "output": "desktop-dist"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "electron/icons/icon.icns",
      "category": "public.app-category.finance"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "electron/icons/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "solvys-technologies",
      "repo": "fintheon"
    }
  }
}
