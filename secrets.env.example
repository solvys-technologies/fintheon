# ============================================
# Fintheon Development Environment Variables Template
# ============================================
# Copy this file to secrets.env and fill in your actual values
# DO NOT commit secrets.env to git

# Neon Database (Development / Production)
# Always prefer NEON_DATABASE_URL. DATABASE_URL is deprecated.
NEON_DATABASE_URL="postgres://user@localhost:5432/fintheon_dev"
# Optional legacy fallback (not recommended)
# DATABASE_URL="postgres://user:password@ep-xyz.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Sentry (Backend + Frontend)
# Use the same DSN for both or separate projects per stack
SENTRY_DSN="https://public-key.ingest.us.sentry.io/project-id"
SENTRY_TRACES_SAMPLE_RATE="0.1"
SENTRY_PROFILES_SAMPLE_RATE="0.1"
# ============================================
# Fintheon Frontend Environment Variables for Vercel (Vite)
# ============================================
# Note: Vite uses VITE_ prefix (not NEXT_PUBLIC_)
# Set these in Vercel Dashboard → Settings → Environment Variables

# Backend API URL (Fly.io deployment)
VITE_API_URL=https://fintheon.fly.dev

# Supabase Authentication (Frontend)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY

# ============================================
# AI Gateway Configuration - Multi-Provider Architecture
# ============================================
# OpenRouter Primary Provider (200+ models via unified gateway)
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_API_KEY

# OpenRouter App Attribution (for OpenRouter dashboard tracking)
OPENROUTER_APP_URL=https://fintheon.vercel.app
OPENROUTER_APP_NAME=Fintheon-AI-Gateway

# Provider Selection
# Options: 'openrouter' (default) or 'vercel-gateway'
AI_PRIMARY_PROVIDER=openrouter

# Enable cross-provider fallback (OpenRouter → Vercel Gateway)
AI_ENABLE_PROVIDER_FALLBACK=true

# Default model for general chat (uses task-based routing if not set)
# Options: sonnet, grok, groq (via Vercel), openrouter-sonnet, openrouter-llama
# AI_DEFAULT_MODEL=grok

# Vercel AI Gateway (fallback provider)
# Shared key for Vercel AI Gateway (all backend models route through this)
VERCEL_AI_GATEWAY_API_KEY=YOUR_VERCEL_AI_GATEWAY_API_KEY
# Optional: override the default gateway URL
# VERCEL_AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1/chat/completions

# ============================================
# Fintheon Backend Environment Variables (Fly.io / local backend)
# ============================================
# Clerk Secret Key - server-side only
CLERK_SECRET_KEY=YOUR_CLERK_SECRET_KEY

# JWKS endpoint for template tokens (RS256)
# Format: https://<clerk-domain>/.well-known/jwks.json
CLERK_JWKS_URL=YOUR_CLERK_JWKS_URL

# Optional: issuer/audience validation if you want strict checks
# CLERK_JWT_ISSUER=https://<clerk-domain>
# CLERK_JWT_AUDIENCE=YOUR_AUDIENCE

# ============================================
# Supabase (primary data store — replaces Notion)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ============================================
# Clerk Authentication (Backend — server-side)
# ============================================
# CLERK_SECRET_KEY is also listed above — only set it once
# CLERK_JWKS_URL is also listed above

# ============================================
# Hermes / Nous Research (agent inference)
# ============================================
HERMES_NOUS_BASE_URL=https://inference-api.nousresearch.com/v1
