{
  "mcpServers": {
    "tradingview": {
      "command": "npx",
      "args": ["-y", "tradingview-mcp-server"]
    },
    "exa": {
      "command": "npx",
      "args": ["-y", "exa-mcp-server"],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      }
    },
    "framer": {
      "type": "url",
      "url": "https://mcp.unframer.co/mcp?id=b1caf95b05d6180110aca64b500470d1405d8d7595ef94f5120a5791c2b70c41&secret=cMzos9tRvg64Rnnho3cXA3BH61EOlC6r"
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\":\"Bearer ${NOTION_API_KEY}\",\"Notion-Version\":\"2022-06-28\"}"
      }
    },
    "close_crm": {
      "command": "npx",
      "args": ["-y", "close-mcp-server"],
      "env": {
        "CLOSE_API_KEY": "${CLOSE_API_KEY}"
      }
    }
  }
}
