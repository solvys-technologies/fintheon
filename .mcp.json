{
  "mcpServers": {
    "tradingview": {
      "command": "node",
      "args": [
        "/Users/tifos/Documents/Codebases/tradingview-mcp/src/mcp-server.js"
      ]
    },
    "exa": {
      "command": "npx",
      "args": ["-y", "exa-mcp-server"],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      }
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\":\"Bearer ${NOTION_API_KEY}\",\"Notion-Version\":\"2022-06-28\"}"
      }
    },
    "unusual-whales": {
      "command": "npx",
      "args": ["-y", "unusual-whales-mcp"],
      "env": {
        "UNUSUAL_WHALES_API_KEY": "${UW_API_KEY}"
      }
    }
  }
}
