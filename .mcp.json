{
  "mcpServers": {
    "tradingview": {
      "command": "node",
      "args": ["/Users/tifos/Desktop/Codebases/tradingview-mcp/src/server.js"]
    },
    "exa": {
      "command": "npx",
      "args": ["-y", "exa-mcp-server"],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      }
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\":\"Bearer ${NOTION_API_KEY}\",\"Notion-Version\":\"2022-06-28\"}"
      }
    },
    "claude-peers": {
      "command": "bun",
      "args": ["/Users/tifos/claude-peers-mcp/server.ts"]
    }
  }
}
