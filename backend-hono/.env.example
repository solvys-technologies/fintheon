# [claude-code 2026-05-04] Install maintenance audit: documented source-referenced optional env vars and platform-injected flags.
# [claude-code 2026-05-03] S58 deploy: document DeepSeek provider chain env and remove concrete database credentials.
# [claude-code 2026-05-13] S64 deploy: add CAO_EVENING_REVIEW_ENABLED.
# ============================================================================
# Fintheon Backend — Environment Configuration
# Copy to .env and fill in your values. Do NOT commit .env with secrets.
# ============================================================================

# --- Core -------------------------------------------------------------------

# Server port (default: 8080)
PORT=8080

# Node environment
NODE_ENV=development

# App version (auto-read from package.json if not set)
# FINTHEON_VERSION=1.0.0

# App URL for Playwright screenshots (default: http://localhost:5173)
# FINTHEON_APP_URL=http://localhost:5173

# --- Auth --------------------------------------------------------------------

# Bypass Supabase JWT auth for local dev / Electron mode
BYPASS_AUTH=true

# Supabase auth — OPTIONAL. Only needed for production multi-user auth.
# New users: SKIP THESE. The app works without them.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Database ----------------------------------------------------------------

# Supabase Postgres (pooler) — shared database for all Fintheon peers
# IMPORTANT: Use the pooler URL (pooler.supabase.com), NOT the direct connection (db.*.supabase.co)
# Direct connections only have IPv6 and will fail on most networks.
# URL-encode special chars in password (e.g. $ → %24)
DATABASE_URL=
# Optional alias accepted by backend boot if DATABASE_URL is unset.
# NEON_DATABASE_URL=

# Connection pool tuning (only relevant if DATABASE_URL is set)
# DB_POOL_MAX=10
# DB_IDLE_TIMEOUT_MS=30000
# DB_CONNECT_TIMEOUT_MS=5000

# --- AI / Inference ----------------------------------------------------------

# Primary AI provider: deepseek-direct | hermes | openrouter | vercel-gateway
AI_PRIMARY_PROVIDER=deepseek-direct

# OpenRouter (optional fallback)
OPENROUTER_API_KEY=
OPENROUTER_APP_URL=https://fintheon.vercel.app
OPENROUTER_APP_NAME=Fintheon-AI-Gateway
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# DeepSeek v4 Pro primary provider (OpenAI-compatible)
DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_DIRECT_ENABLED=true

# OpenCode Go / Hermes local OpenAI-compatible fallback
# OPENCODE_GO_API_KEY=
# OPENCODE_GO_API_URL=http://localhost:8081/v1
# HERMES_API_KEY=
# HERMES_API_URL=http://localhost:8081/v1

# Ollama / Groq alternates for Fintheon Arbitrum and fallback routing
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_API_KEY=
# OLLAMA_FALLBACK_MODEL=qwen3.5:397b-cloud
# GROQ_API_KEY=

# User API-key encryption. Set to a long random secret in production.
ENCRYPTION_SECRET=

# Default model override (default: openrouter-opus if OPENROUTER_API_KEY set)
# AI_DEFAULT_MODEL=openrouter-opus

# Cross-provider fallback (default: true)
# AI_ENABLE_PROVIDER_FALLBACK=true

# Vercel AI Gateway (optional — alternative to OpenRouter)
# VERCEL_AI_GATEWAY_API_KEY=
# VERCEL_AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1/chat/completions

# Nous Research direct inference (fallback when OpenRouter DNS fails)
# Get key at https://portal.nousresearch.com — uses Hermes 4 405B
NOUS_API_KEY=

# OpenAI — voice transcription (Whisper) + TTS
OPENAI_API_KEY=
# OPENAI_TRANSCRIBE_MODEL=whisper-1
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=alloy

# --- Hermes Agent ------------------------------------------------------------

# Hermes CLI binary path (default: hermes)
# HERMES_BINARY_PATH=hermes

# Hermes base URL (default: uses OPENROUTER_BASE_URL)
# HERMES_BASE_URL=

# Hermes app name (default: Fintheon-PIC-Hermes)
# HERMES_APP_NAME=Fintheon-PIC-Hermes

# Local Hermes toggle (default: true — use local hermes process)
# USE_LOCAL_HERMES=true

# Streaming chunk delays (ms) for smooth UI rendering
# HERMES_STREAM_CHUNK_DELAY_MS=18
# HERMES_REASONING_CHUNK_DELAY_MS=14

# Hermes sessions send URL (for session callbacks)
# HERMES_SESSIONS_SEND_URL=http://localhost:47832/api/sessions/send

# --- Claude Code SDK Bridge --------------------------------------------------

# Claude CLI binary path (default: claude)
# CLAUDE_BINARY_PATH=claude
# CLAUDE_SDK_MODEL=opus
# CLAUDE_SDK_EFFORT=high
# CLAUDE_SDK_MAX_TURNS=3
# CLAUDE_SDK_TIMEOUT_MS=120000
# CLAUDE_SDK_CWD=
# CLAUDE_SDK_SYSTEM_PROMPT=
# CLAUDE_SDK_SKIP_PERMISSIONS=false
# CLAUDE_SDK_MAX_CONCURRENT=2

# --- AI Conversation Settings ------------------------------------------------

# Max messages retained in conversation history (default: 50)
# AI_MAX_HISTORY_MESSAGES=50

# Max tokens for context window (default: 100000)
# AI_MAX_CONTEXT_TOKENS=100000

# Token threshold to trigger summarization (default: 80000)
# AI_SUMMARIZATION_THRESHOLD=80000

# Slow response warning threshold in ms (default: 3000)
# AI_SLOW_RESPONSE_MS=3000

# --- Cron / Scheduling -------------------------------------------------------

# Boardroom meeting schedule (weekdays, America/New_York)
HERMES_BOARDROOM_CRON=0,30 7-9 * * 1-5
HERMES_BOARDROOM_TZ=America/New_York
BOARDROOM_MEETING_WINDOW_MINUTES=90
BOARDROOM_MEETING_HOUR_LOCAL=10

# Pre/post market briefing schedules (ET)
HERMES_PREMARKET_CRON=0 8 * * 1-5
HERMES_POSTMARKET_CRON=30 16 * * 1-5

# Dispatch scheduler (MDB/ADB/PMDB/TOTT generation)
DISPATCH_SCHEDULER_ENABLED=true

# Cron auth token (for /cron/ endpoints)
# CRON_SECRET_TOKEN=

# --- External Services -------------------------------------------------------

# Rettiwt-API auth token (primary Twitter search fallback)
RETTIWT_AUTH_TOKEN=

# Deprecated curated timeline scraper quarantine. Keep disabled unless TP explicitly reactivates it.
RISKFLOW_COMMENTARY_SCRAPER=disabled

# FRED economic data API (St. Louis Fed)
FRED_API_KEY=

# Public.com market data (read-only in Fintheon S102; no order placement)
PUBLIC_API_KEY=
PUBLIC_ACCOUNT_ID=
PUBLIC_API_BASE=https://api.public.com

# Notion API (legacy — migrating to Supabase)
NOTION_API_KEY=

# Twitter CLI binary path (default: ~/.local/bin/twitter)
# TWITTER_CLI_PATH=

# --- Trading Infrastructure --------------------------------------------------

# Primary broker: rithmic | projectx | hyperliquid (default: rithmic)
# PRIMARY_BROKER=rithmic

# Primary trading instrument (default: /ES)
# PRIMARY_INSTRUMENT=/ES

# Rithmic gateway URL (default: http://localhost:3002)
# RITHMIC_GATEWAY_URL=http://localhost:3002

# Hyperliquid DEX (perpetual futures on Arbitrum)
# HYPERLIQUID_PRIVATE_KEY=
# HYPERLIQUID_VAULT_ADDRESS=
# HYPERLIQUID_TESTNET=false

# Kalshi Prediction Markets (RSA key auth) — managed by separate sprint
# KALSHI_API_KEY=
# KALSHI_RSA_PRIVATE_KEY=
# KALSHI_EMAIL=
# KALSHI_PASSWORD=
# KALSHI_API_URL=https://trading-api.kalshi.com/trade-api/v2

# Execution Bridge (ProjectX via project-x-py)
BRIDGE_URL=http://localhost:8001
PROJECTX_API_URL=https://api.topstepx.com
PROJECTX_API_KEY=
PROJECTX_USERNAME=

# Reconciler
HARD_STOP_TIME=11:30
PDPT_FLOOR=1500
MAX_CONCURRENT_POSITIONS=1
MAX_ORDERS_PER_MINUTE=2
CONFIRMATION_TIMEOUT_SEC=8
DUPLICATE_WINDOW_SEC=30

# --- Feature Flags -----------------------------------------------------------

# JSON blob of feature flags (default: all enabled)
# FINTHEON_FEATURE_FLAGS={"brief":true,"validate":true,"report":true,"track":true,"psych_assist":true,"maintenance":true,"quick_fintheon":true,"agentDesk":false,"chart_levels":true}

# Individual feature toggles
# ENABLE_AI_ANALYSIS=true
# ENABLE_CENTRAL_SCORING=false
# RISKFLOW_ALLOW_MOCK_FALLBACK=false

# Worker-owned browser session for X/RiskFlow collection
# BROWSER_WORKER_SESSION_DIR=.runtime/browser-session
# BROWSER_WORKER_HEADLESS=true
# BROWSER_WORKER_USER_AGENT=

# Agent Desk multi-agent simulation (optional)
# AGENT_DESK_ENABLED=false

# --- ProxVoice — self-hosted LiveKit ----------------------------------------
# Fly app target: fintheon-livekit. LIVEKIT_URL may be ws://localhost:7880 for
# local tests or wss://fintheon-livekit.fly.dev in production.
# Local values are copied into the global server_secrets vault by the backend so
# ProxVoice works for every authenticated user instead of only one local .env.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://fintheon-livekit.fly.dev

# --- Runtime / Platform -------------------------------------------------------
# Usually injected by the shell, Electron, Fly, or CI. Set only when overriding.
# HOME=/Users/you
# FINTHEON_DESKTOP=false
# FINTHEON_PROJECT_ROOT=/Users/you/Documents/Codebases/fintheon
# FINTHEON_FILE_ROOM_PATH=/Users/you/Documents/Fintheon/File Room
# FLY_APP_NAME=
# GH_TOKEN=
# GITHUB_TOKEN=

# --- Supabase extended -------------------------------------------------------
# SUPABASE_ANON_KEY — backfilled by fintheon-update.sh Step 5; safe to leave blank for Electron mode.
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY — admin ops (migrations, user mgmt). No default. Get from Supabase dashboard.
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_BOOT_USER_ID — optional user ID to bootstrap as owner on a fresh install
# SUPABASE_BOOT_USER_ID=
# SUPABASE_MAGIC_LINK_REDIRECT — where magic links send users back to (default: app homepage)
# SUPABASE_MAGIC_LINK_REDIRECT=http://localhost:5173/auth/callback
# SUPER_ADMIN_USER_ID — user allowed to approve maintenance requests + super-admin flows
# SUPER_ADMIN_USER_ID=
# SUPER_ADMIN_EMAIL=
# Poll owner — who owns the scheduled polls + Supabase-driven dispatchers
# POLL_OWNER_ID=
# POLL_OWNER_EMAIL=

# --- Relay (peer-to-peer mobile <-> desktop sync) ---------------------------
# Relay WebSocket bridge between desktop Electron + mobile PWA over a shared room.
# Disabled by default; enable with RELAY_ENABLED=true.
# RELAY_ENABLED=false
# RELAY_WS_URL=ws://localhost:8084/relay
# RELAY_USER_ID=
# RELAY_AUTH_TOKEN=

# --- Web Push (VAPID) --------------------------------------------------------
# Keys for Web Push notifications to the mobile PWA. Generate with:
#   npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:tp@pricedinresearch.io

# --- Peer Network ------------------------------------------------------------
# Optional multi-device configuration (each Fintheon install can register as a peer)
# PEER_AUTO_REGISTER=false
# PEER_BOOT_USER_ID=
# PEER_DEVICE_NAME=
# PEER_ENABLE_TWITTER=false
# FINTHEON_PEER_CONFIG=

# --- Agent Routines ----------------------------------------------------------
# Toggle + pacing for Hermes / Oracle / Harper background routines.
# HERMES_ENABLED=true
# HARPER_AUTONOMOUS_ENABLED=false
# CAO_EVENING_REVIEW_ENABLED=false
# ORACLE_RESEARCH_ENABLED=false
# ORACLE_RESEARCH_INTERVAL_MS=3600000
# ENABLE_MONITORING_LOOP=false
# MONITORING_LOOP_CRON=*/5 * * * *
# ENABLE_REFLECT=false
# REFLECT_VIA_ROUTINE=false
# MARKET_IMPACT_VIA_ROUTINE=false
# PREDICTION_RESOLVER_VIA_ROUTINE=false
# ENABLE_COMPUTER_USE=false
# ROUTINE_SECRET=                         # shared secret for routine/admin cron endpoints
# SYSTEM_USER_ID=                         # fallback UUID for scheduled jobs without session auth
# TV_ANTILAG_WEBHOOK_SECRET=              # TradingView Antilag alert payload/header secret
# DAY_PLAN_CRON_ENABLED=true
# DESK_PLAN_CRON_ENABLED=true
# DRIFT_MONITOR_CRON_ENABLED=true
# STREAK_CRON_ENABLED=true
# DAY_PLAN_STREAK_USER_IDS=               # comma-separated UUIDs; falls back to SYSTEM_USER_ID

# --- Arbitrum / Risk Triggers -------------------------------------------------
# Fintheon Arbitrum session and event-driven chamber triggers. Defaults are on.
# ARBITRUM_SESSION_SCHEDULER_ENABLED=true
# ARBITRUM_EVENT_TRIGGER_ENABLED=true
# ARBITRUM_EVENT_IV_THRESHOLD=8.5
# ARBITRUM_EVENT_TOP_N=10
# ECON_CALENDAR_ENABLED=true
# COMMENTARY_WATCH_ENABLED=true

# Claude SDK session budgeting (caps daily token spend, refreshes at ET hour)
# CLAUDE_SESSION_DAILY_CAP=5000000
# CLAUDE_SESSION_REFRESH_HOUR_ET=6

# --- Scoring v4 --------------------------------------------------------------
# Opt-in to the next-generation RiskFlow scorer (default: v3 legacy).
# SCORING_V4=false
# SCORING_V4_VERBOSE=false

# Minimum vote threshold for Bulletin promotion (default: 3)
# BULLETIN_VOTE_THRESHOLD=3

# --- External Services (cont.) -----------------------------------------------
# Firecrawl — optional scraper fallback for AgentReach
# FIRECRAWL_API_KEY=

# Browserbase hosted browser sessions — optional, skipped when unset.
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
# BROWSERBASE_REGION=us-east-1

# Steel browser agent bridge — optional, skipped when STEEL_API_BASE is unset.
# STEEL_API_BASE=
# STEEL_API_KEY=
# STEEL_PROXY_URL=

# XActions bridge — optional remote X automation service.
# XACTIONS_API_BASE=

# ElevenLabs / VibeVoice voice backends — optional; audio/STT omitted when unset.
# ELEVENLABS_API_KEY=
# ELEVENLABS_DISABLE=false
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# VIBEVOICE_ASR_URL=
# VOICE_STT_PROVIDER=auto
# OMI_API_BASE=https://api.omi.me/v1/dev

# --- S59: Native Hermes Agent Core (T1) -------------------------------------
# Hermes Python sidecar deleted S59-T1. Agent runtime is now native TypeScript
# in backend-hono/src/services/hermes/. No sidecar env vars needed — everything
# runs in-process. Chat routes through DeepSeek v4 Pro (DEEPSEEK_API_KEY).

# --- S27: Browser Primitives (T4) / Harper Browser Operator (T6) -------------
# Universal mode lets browseRead hit arbitrary domains at $0.01/URL. Off by
# default — only allow-listed domains reachable. Turn on deliberately for T6.
# BROWSER_UNIVERSAL_ENABLED=false
# RETTIWT_REENABLE=false                 # Flip back to true if browser-harness coverage regresses for X/Twitter

# --- S27: Smart Model Routing (T9) -------------------------------------------
# Per-user daily USD cap; Harper+Oracle Opus→Sonnet degrade on cap exceed.
# ROUTING_DAILY_CAP=20
# ROUTING_DISABLE_BUDGET=false           # TP's own account should set true to bypass the cap

# Harper provider toggle: qwen|deepseek (default: deepseek)
# When set to "qwen", Harper uses qwen3.5:397b-cloud via Hermes sidecar ($0 cost)
# When set to "deepseek", Harper uses the DeepSeek/Hermes provider chain
# HARPER_DEFAULT_PROVIDER=deepseek

# Sub-agent models (all locked to qwen3.5:397b-cloud via Hermes as of S28)
# ROUTING_OVERRIDE_HARPER=               # claude-opus-4-7  (default); override to A/B
# ROUTING_OVERRIDE_ORACLE=               # qwen3.5:397b-cloud (default)
# ROUTING_OVERRIDE_FEUCHT=               # qwen3.5:397b-cloud (default)
# ROUTING_OVERRIDE_CONSUL=               # qwen3.5:397b-cloud (default)
# ROUTING_OVERRIDE_HERALD=               # qwen3.5:397b-cloud (default)
# ROUTING_OVERRIDE_HARPER_VOICE=         # qwen/qwen3.6-plus-preview:free (default)

# --- RiskFlow Worker (S27 T7, updated S55, S57) -------------------------------
# Sibling process on :8082. Writes to raw_riskflow_items when flag is true.
# Uses persistent browser session to scrape x.com/home timeline.
# FLAG_RISKFLOW_WORKER_WRITES_RISKFLOW=true  # (legacy: FLAG_NEWS_WORKER_WRITES_RISKFLOW)
# FLAG_NEWS_WORKER_WRITES_RISKFLOW=true      # legacy alias retained by worker paths
# NEWS_WORKER_PORT=8082
# RISKFLOW_WORKER_PORT=8082                  # preferred worker port alias
# NEWS_WORKER_AUDIT_ENABLED=false
# X_AUTH_TOKEN=                            # auth_token cookie from logged-in X session
# X_CT0_TOKEN=                             # ct0 cookie from logged-in X session
# X_EMAIL=                                 # email/username for X auto-login (token refresh)
# X_PASSWORD=                              # password for X auto-login
# X_AUTH_ACCOUNTS=                         # optional multi-account rotation: "user1:pass1,user2:pass2"
# X_AUTH_COOKIES=                          # JSON cookie array for browser login injection
# X_RETTIWT_COOKIES=                       # JSON cookie array for Rettiwt fallback pool
# X_BURNER_LIST_URL=https://x.com/i/lists/0
# X_BURNER_USER=
# X_BURNER_PASS=
# X_BURNER_TOTP=
# BROWSER_WORKER_HEADLESS=false            # set to true to run Playwright headless
# POLLING_DEVICE_ID=main                   # device identity for round-robin coordinator
# POLLING_ROTATION_MINUTES=90              # how long each device polls before rotating
# TWITTER_STREAMING_ENABLED=true
# TWITTER_EMERGENCY_FIRESTREAM=false

# --- Econ / Commentary Schedulers --------------------------------------------
# All default on unless explicitly disabled; external keys remain optional.
# ECON_POPULATOR_ENABLED=true
# ECON_BACKFILL_ENABLED=true
# ECON_KEYWORD_TRIGGER_ENABLED=true
# ECON_CALENDAR_ENABLED=true
# FISCAL_SPEAKER_POPULATOR_ENABLED=true
# MEGACAP_EARNINGS_ENABLED=true
# MEGACAP_EARNINGS_ENRICHMENT_ENABLED=true
# POLYMARKET_SCREENER_ENABLED=false

# --- ProjectX / Trading Sync --------------------------------------------------
# Optional ProjectX trade sync; skipped unless API key and account id are present.
# PROJECTX_ACCOUNT_ID=
# PROJECTX_USER_ID=
# PROJECTX_SYNC_DISABLED=false

# --- S27: GEPA Self-Improvement (T11) ----------------------------------------
# Nightly DSPy-backed prompt optimization. Opens PRs against soul-evolution/
# branches; never auto-merges. DRY_RUN keeps pr-creator local; DEEP swaps
# shallow mutation for full DSPy optimizer (requires dspy-ai installed).
# GEPA_DRY_RUN=false
# GEPA_DEEP=false

# --- S27: Voice Assistant (T5) -----------------------------------------------
# Fall back to legacy OpenAI-direct voice path if sidecar has voice issues.
# VOICE_SIDECAR_DISABLED=false

