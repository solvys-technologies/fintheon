# ============================================================================
# Fintheon Backend — Environment Configuration
# ============================================================================
# Copy to .env:  cp backend-hono/.env.example backend-hono/.env
#
# The app works out of the box with these defaults.
# The ONLY thing you need to add for AI features is OPENROUTER_API_KEY.
# ============================================================================

# --- Core -------------------------------------------------------------------

PORT=8080
NODE_ENV=development
BYPASS_AUTH=true

# --- Supabase (production defaults — publishable keys, safe to embed) -------

SUPABASE_URL=https://nrcfnzclbjboctptxaxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5yY2ZuemNsYmpib2N0cHR4YXh4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM5NDgxODksImV4cCI6MjA4OTUyNDE4OX0.JXzVk5CDL6rxU5t_rl-Ku2YnPi0PeBF-VOpcSEZTbIM

# Service role key — only set this if you're an admin running multi-user mode.
# New users: SKIP THIS. The app works without it.
# SUPABASE_SERVICE_ROLE_KEY=

# --- Database ----------------------------------------------------------------
# OPTIONAL — The app works fully without a database (in-memory fallback).
# New users: DO NOT set these. Skip entirely.
# DATABASE_URL=postgresql://...
# NEON_DATABASE_URL=

# --- AI / Inference ----------------------------------------------------------

# Primary AI provider: openrouter (default) | hermes | vercel-gateway
AI_PRIMARY_PROVIDER=openrouter

# OpenRouter — the only key needed for AI features
# Get your key at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
OPENROUTER_APP_URL=https://fintheon.vercel.app
OPENROUTER_APP_NAME=Fintheon-AI-Gateway

# Cross-provider fallback (OpenRouter → Vercel Gateway)
AI_ENABLE_PROVIDER_FALLBACK=true

# Nous Research direct inference (fallback when OpenRouter DNS fails)
# NOUS_API_KEY=

# OpenAI — voice transcription (Whisper) + TTS only
# OPENAI_API_KEY=

# GitHub OAuth (for GitHub Models free fallback — GPT-4o)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=http://localhost:5173/auth/github/callback

# --- Hermes Agent ------------------------------------------------------------

# Hermes uses OPENROUTER_API_KEY by default — no extra config needed.
# USE_LOCAL_HERMES=true

# --- Scheduling (pre-configured for ET trading hours) ------------------------

HERMES_BOARDROOM_CRON=0,30 7-9 * * 1-5
HERMES_BOARDROOM_TZ=America/New_York
BOARDROOM_MEETING_WINDOW_MINUTES=90
BOARDROOM_MEETING_HOUR_LOCAL=10
HERMES_PREMARKET_CRON=0 8 * * 1-5
HERMES_POSTMARKET_CRON=30 16 * * 1-5
DISPATCH_SCHEDULER_ENABLED=true

# --- External Services (all optional) ----------------------------------------

# EXA_API_KEY=
# FIRECRAWL_API_KEY=
# FRED_API_KEY=
# NOTION_API_KEY=

# --- Execution Bridge --------------------------------------------------------

BRIDGE_URL=http://localhost:8001
# PROJECTX_API_KEY=
# PROJECTX_USERNAME=

# --- Reconciler Defaults -----------------------------------------------------

HARD_STOP_TIME=11:30
PDPT_FLOOR=1500
MAX_CONCURRENT_POSITIONS=1
MAX_ORDERS_PER_MINUTE=2
CONFIRMATION_TIMEOUT_SEC=8
DUPLICATE_WINDOW_SEC=30
