# =============================================================================
# Fintheon Backend — Environment Variables Template
# =============================================================================
# Usage:
#   cp .env.template .env
#   Fill in every line marked [REQUIRED] or [CRITICAL] before starting the server.
#   Lines marked [OPTIONAL] have safe defaults; override only if needed.
#   Lines marked [DEV ONLY] must NOT be set in production.
#
# Notation:
#   [CRITICAL]  — server refuses to start if absent
#   [REQUIRED]  — needed for correct behavior; missing causes silent failures
#   [OPTIONAL]  — has a default; override to customize
#   [DEV ONLY]  — dangerous or meaningless in production; omit from prod .env
#   [DISABLED]  — feature not currently active; include if re-enabling
# =============================================================================


# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------

# Runtime environment. Set to 'production' on all deployed instances.
# [REQUIRED]
NODE_ENV=production

# HTTP port the server listens on.
# [OPTIONAL] default: 8080
PORT=8080

# Primary Postgres connection string (Neon).
# Provide exactly one of DATABASE_URL or NEON_DATABASE_URL.
# [CRITICAL]
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Alias accepted by Neon SDK integrations. Set to the same value as DATABASE_URL
# if your driver reads this key specifically.
# [OPTIONAL — mirrors DATABASE_URL]
# NEON_DATABASE_URL=


# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

# Supabase project URL (e.g. https://xyzcompany.supabase.co)
# [CRITICAL]
SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase service role key — grants full DB access, keep secret.
# [CRITICAL]
SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------

# Set to 'true' to bypass JWT auth entirely. NEVER set in production.
# [DEV ONLY]
# BYPASS_AUTH=true


# -----------------------------------------------------------------------------
# AI / Model Providers
# -----------------------------------------------------------------------------

# Primary AI gateway (Nous/OpenRouter subscription).
# All AI inference routes through this key.
# [CRITICAL]
OPENROUTER_API_KEY=

# HTTP Referer header sent with OpenRouter requests.
# [OPTIONAL] default: https://fintheon-solvys.vercel.app
# OPENROUTER_APP_URL=https://fintheon-solvys.vercel.app

# X-Title header sent with OpenRouter requests.
# [OPTIONAL] default: Fintheon-AI-Gateway
# OPENROUTER_APP_NAME=Fintheon-AI-Gateway

# OpenAI direct API key — used as fallback when OpenRouter is unavailable.
# [OPTIONAL]
OPENAI_API_KEY=

# Vercel AI Gateway key — only needed if routing through Vercel's AI proxy.
# [OPTIONAL]
VERCEL_AI_GATEWAY_API_KEY=

# Exa Search API — powers deep research and scheduled news monitoring.
# [REQUIRED] (news monitoring degrades without it)
EXA_API_KEY=


# -----------------------------------------------------------------------------
# Claude CLI  (briefs + chat; NOT used for headline scoring)
# -----------------------------------------------------------------------------

# Path to the `claude` binary. Defaults to searching PATH.
# [OPTIONAL] default: claude
# CLAUDE_BINARY_PATH=claude

# Model identifier passed to the Claude CLI.
# [OPTIONAL] default: opus
# CLAUDE_SDK_MODEL=opus

# Effort level: low | medium | high
# [OPTIONAL] default: high
# CLAUDE_SDK_EFFORT=high

# Maximum conversation turns per Claude CLI invocation.
# [OPTIONAL] default: 3
# CLAUDE_SDK_MAX_TURNS=3

# Timeout in milliseconds for a single Claude CLI call.
# [OPTIONAL] default: 300000 (5 minutes)
# CLAUDE_SDK_TIMEOUT_MS=300000

# Working directory for Claude CLI subprocess.
# [OPTIONAL]
# CLAUDE_SDK_CWD=

# Override system prompt for all Claude CLI calls.
# [OPTIONAL]
# CLAUDE_SDK_SYSTEM_PROMPT=

# Skip Claude permission checks (use with caution).
# [OPTIONAL]
# CLAUDE_SDK_SKIP_PERMISSIONS=

# Maximum number of concurrent Claude CLI processes.
# [OPTIONAL] default: 2
# CLAUDE_SDK_MAX_CONCURRENT=2


# -----------------------------------------------------------------------------
# Market Data
# -----------------------------------------------------------------------------

# Default futures instrument for point estimation.
# [OPTIONAL] default: /ES
# PRIMARY_INSTRUMENT=/ES

# FRED (Federal Reserve Economic Data) API key.
# Required for macro economic data features.
# [REQUIRED] (macro features degrade without it)
FRED_API_KEY=


# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# MUST be 'true' for the scoring pipeline to run. This is the most common
# misconfiguration cause. Set it explicitly — do not rely on any default.
# [CRITICAL]
ENABLE_CENTRAL_SCORING=true

# Set to 'false' to globally disable AI analysis (e.g. cost control).
# [OPTIONAL] default: true
# ENABLE_AI_ANALYSIS=true

# Allow mock data fallback when live market data is unavailable.
# Set to 'false' in production to prevent silent mock contamination.
# [OPTIONAL] default: false
RISKFLOW_ALLOW_MOCK_FALLBACK=false

# JSON-encoded feature flag overrides. Keys override code-level defaults.
# Example: {"new_dashboard":true,"legacy_charts":false}
# [OPTIONAL]
# FINTHEON_FEATURE_FLAGS=

# Enable or disable the dispatch scheduler.
# [OPTIONAL] default: true
# DISPATCH_SCHEDULER_ENABLED=true


# -----------------------------------------------------------------------------
# Firecrawl  (currently disabled — include only if re-enabling)
# -----------------------------------------------------------------------------

# Firecrawl web scraping API key.
# [DISABLED]
# FIRECRAWL_API_KEY=


# -----------------------------------------------------------------------------
# Hermes / Boardroom
# -----------------------------------------------------------------------------

# Pre-market briefing cron schedule (server local time unless TZ set).
# [OPTIONAL] default: '0 7 * * 1-5'  (07:00 Mon–Fri)
# HERMES_PREMARKET_CRON=0 7 * * 1-5

# Post-market briefing cron schedule.
# [OPTIONAL] default: '30 16 * * 1-5'  (16:30 Mon–Fri)
# HERMES_POSTMARKET_CRON=30 16 * * 1-5

# Boardroom meeting cron schedule.
# [OPTIONAL]
# HERMES_BOARDROOM_CRON=

# Timezone for boardroom scheduling (IANA format, e.g. America/New_York).
# [OPTIONAL]
# HERMES_BOARDROOM_TZ=America/New_York

# Path to the Hermes binary.
# [OPTIONAL]
# HERMES_BINARY_PATH=

# Milliseconds delay between streamed text chunks.
# [OPTIONAL] default: 18
# HERMES_STREAM_CHUNK_DELAY_MS=18

# Milliseconds delay between streamed reasoning chunks.
# [OPTIONAL] default: 14
# HERMES_REASONING_CHUNK_DELAY_MS=14

# Use local Hermes process instead of remote.
# [OPTIONAL] default: true
# USE_LOCAL_HERMES=true

# Hour (0–23, local time) at which Boardroom meeting triggers.
# [OPTIONAL]
# BOARDROOM_MEETING_HOUR_LOCAL=

# Window in minutes around the meeting hour during which late-join is allowed.
# [OPTIONAL]
# BOARDROOM_MEETING_WINDOW_MINUTES=


# -----------------------------------------------------------------------------
# LiveKit  (optional — graceful degradation per S13 design)
# -----------------------------------------------------------------------------

# LiveKit Cloud API key.
# [OPTIONAL] voice/video features disabled if absent
# LIVEKIT_API_KEY=

# LiveKit Cloud API secret.
# [OPTIONAL]
# LIVEKIT_API_SECRET=

# LiveKit WebSocket server URL (wss://...).
# [OPTIONAL]
# LIVEKIT_URL=wss://<project>.livekit.cloud


# -----------------------------------------------------------------------------
# Database Connection Pool Tuning
# -----------------------------------------------------------------------------

# Maximum number of pooled Postgres connections.
# [OPTIONAL] default: 10
# DB_POOL_MAX=10

# Milliseconds before an idle connection is closed.
# [OPTIONAL] default: 30000
# DB_IDLE_TIMEOUT_MS=30000

# Milliseconds before a connection attempt times out.
# [OPTIONAL] default: 5000
# DB_CONNECT_TIMEOUT_MS=5000


# -----------------------------------------------------------------------------
# Autopilot / Broker Bridge
# -----------------------------------------------------------------------------

# Active broker adapter: rithmic | projectx | hyperliquid
# [OPTIONAL] default: rithmic
# PRIMARY_BROKER=rithmic

# URL of the local broker bridge process.
# [OPTIONAL] default: http://localhost:8001
# BRIDGE_URL=http://localhost:8001


# -----------------------------------------------------------------------------
# Cron Webhook Auth
# -----------------------------------------------------------------------------

# Shared secret validated on all incoming cron webhook requests.
# Required when cron jobs are active in production.
# [REQUIRED in prod if cron is active]
CRON_SECRET_TOKEN=


# -----------------------------------------------------------------------------
# Version
# -----------------------------------------------------------------------------

# Override the version string reported by /api/version.
# Defaults to the version in package.json.
# [OPTIONAL]
# FINTHEON_VERSION=
