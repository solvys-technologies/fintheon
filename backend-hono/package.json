    "@neondatabase/serverless": "^0.10.4",
    "@sentry/node": "^10.32.1",
    "@sentry/profiling-node": "^10.32.1",
    "@strands-agents/sdk": "^1.0.0-rc.2",
    "@supabase/supabase-js": "^2.99.3",
    "ai": "^6.0.116",
    "cron-parser": "^5.5.0",
    "dotenv": "^16.5.0",
    "hono": "^4.6.0",
    "livekit-server-sdk": "^2.15.0",
    "node-cron": "^4.2.1",
    "openai": "^6.33.0",
    "pg": "^8.16.3",
