# [claude-code 2026-04-23] Windows desktop build — remote-backend mode.
# Loaded by `vite build --mode windows` (see package.json release:win script).
# Desktop Windows installs have no local backend; the renderer hits fintheon.fly.dev directly.
VITE_API_URL=https://fintheon.fly.dev
VITE_CLIENT_TARGET=https://fintheon.fly.dev
